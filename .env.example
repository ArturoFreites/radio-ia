# Copiar a .env para Docker Compose:  cp .env.example .env
# Para desarrollo local sin Docker:    cp .env.example .env.local

# --- Base de datos y colas (Docker usa hostnames db/redis) ---
DATABASE_URL=postgresql://radioflow:radioflow@localhost:5433/radioflow
REDIS_URL=redis://localhost:6379

# --- APIs de IA (obligatorias) ---
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_PREVIEW_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_DEFAULT_VOICE_ID=QK4xDwo9ESPHA4JNUpX3
ELEVENLABS_FREE_FALLBACK_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# Opcional: alertas de cuota ElevenLabs (caracteres restantes)
ELEVENLABS_QUOTA_ALERTA_MIN=
ELEVENLABS_QUOTA_BLOQUEO_MIN=

# Tarifas estimadas USD (dashboard de consumo)
GEMINI_COST_INPUT_USD_PER_1M=0.30
GEMINI_COST_OUTPUT_USD_PER_1M=2.50
ELEVENLABS_COST_FLASH_USD_PER_1K_CHARS=0.05
ELEVENLABS_COST_MULTILINGUAL_USD_PER_1K_CHARS=0.10

# --- Auth ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Storage de audio ---
AUDIO_STORAGE_PATH=./storage/audio

# --- Spotify (opcional) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback
SPOTIFY_DEFAULT_MARKET=AR

# --- Docker ---
# 1 = omitir seed en reinicios (DB ya inicializada)
DOCKER_SKIP_SEED=0
